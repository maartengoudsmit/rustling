<article class="timeline-item photo">
  {% if photo.data.draft %}
    {% render 'draftBanner' %}
  {% endif %}
  <div class="photo-main">
    <img src="{{ photo.data.image }}" alt="{{ photo.content }}">
  </div>
  <div class="photo-caption">{{ photo.content }}</div>
  <div class="item-meta">
    <a href="{{ photo.url }}" title="First published on {{ photo.data.published }}">
      {{- photo.data.published | relative_date -}}
    </a>
    {%- if photo.data.published != photo.data.updated -%}
      <div title="Last updated on {{ photo.data.updated }}">
        (last updated: {{ photo.data.updated | relative_date }})
      </div>
    {%- endif -%}
    <div class="tags">
      {% for tag in photo.data.tags %}
        {% unless tag == 'photo' %}
          <span class="tag"
            ><a href="/tag/{{ tag | slugify }}">{{ tag }}</a></span
          >
        {% endunless %}
      {% endfor %}
      <span class="camera">📷 {{ photo.data.camera }}</span>
    </div>
  </div>
</article>
